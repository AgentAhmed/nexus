# ============================================================
# NEXUS Environment Variables
# Copy to .env and fill in your keys
# cp .env.example .env
# ============================================================

# ── REQUIRED (at least ONE of these) ─────────────────────────
# Get from: https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=your_gemini_key_here

# ── OPTIONAL — Additional LLM providers ──────────────────────
# Vultr Serverless Inference ($100 hackathon credits)
# Get from: https://my.vultr.com/serverless-inference
VULTR_API_KEY=

# Featherless ($25 hackathon credits, 27k+ open-source models)
# Get from: https://featherless.ai (use hackathon setup guide)
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Vultr inference model to use (when VULTR_API_KEY is set)
VULTR_INFERENCE_MODEL=llama-3.1-70b-instruct-fp8

# OpenAI Whisper fallback (if no Speechmatics key)
OPENAI_API_KEY=

# ── VOICE / TRANSCRIPTION ────────────────────────────────────
# Speechmatics ($200 hackathon credits)
# Get from: https://portal.speechmatics.com (use hackathon coupon)
# If not set → system uses Whisper (OpenAI) → or demo mode
SPEECHMATICS_API_KEY=

# ── EXECUTION INTEGRATIONS (all optional) ────────────────────
# Slack incoming webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Jira — https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=

# ── DEPLOYMENT ───────────────────────────────────────────────
# Set these to your Vultr VM public IP or domain
PUBLIC_API_URL=http://YOUR_VULTR_IP/api
PUBLIC_WS_URL=ws://YOUR_VULTR_IP/ws

# ── OBSERVABILITY ────────────────────────────────────────────
# Set to false to disable Arize Phoenix (saves ~500MB RAM)
ENABLE_PHOENIX=true
PHOENIX_PORT=6006
