# ============================================================
# NEXUS v2 — Environment Configuration
# Copy this file: cp .env.example .env
# Minimum to run: just GROQ_API_KEY  (free, no credit card)
# ============================================================

# ── LLM Model Selection ───────────────────────────────────────────────────────
# Free options (no cost):
#   groq/llama-3.3-70b-versatile    ← best free quality
#   groq/llama-3.1-8b-instant       ← fastest free
#   gemini/gemini-1.5-flash         ← Google free
#   gemini/gemini-2.0-flash-exp     ← Google latest free
#   ollama/llama3.2                 ← local, 100% free, needs Ollama
# Paid options:
#   openai/gpt-4o-mini              ← cheap, very good
#   anthropic/claude-3-5-haiku-20241022
PRIMARY_MODEL=groq/llama-3.3-70b-versatile
FAST_MODEL=groq/llama-3.1-8b-instant

# Embeddings model:
#   gemini/text-embedding-004       ← Google free
#   openai/text-embedding-3-small   ← cheap
#   (empty)                         ← uses local sentence-transformers (free)
EMBEDDING_MODEL=gemini/text-embedding-004

# ── API Keys — add only what you have ────────────────────────────────────────
# Groq (FREE) → get at: console.groq.com → API Keys → Create
GROQ_API_KEY=

# Google Gemini (FREE) → get at: aistudio.google.com → Get API key
GEMINI_API_KEY=

# OpenAI (paid) → platform.openai.com
OPENAI_API_KEY=

# Anthropic (paid) → console.anthropic.com
ANTHROPIC_API_KEY=

# Ollama (local/free) → install from ollama.ai, run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── Speech-to-Text ────────────────────────────────────────────────────────────
# "groq"   → Groq Whisper API (free, recommended) — uses GROQ_API_KEY above
# "openai" → OpenAI Whisper API — uses OPENAI_API_KEY above
# "local"  → faster-whisper on CPU (free, no key needed, slower)
# "demo"   → built-in demo transcript (for testing with zero setup)
STT_PROVIDER=groq

# Whisper model size for local STT: tiny|base|small|medium|large-v3
# base = fast CPU, good enough. large-v3 = best quality, slower.
WHISPER_MODEL_SIZE=base

# ── Execution Integrations (all optional) ────────────────────────────────────
# Add whichever you use — NEXUS works without any of these

# Slack incoming webhook: api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Jira: your-company.atlassian.net, token from id.atlassian.com
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_USER_EMAIL=

# Linear: linear.app → Settings → API
LINEAR_API_KEY=

# Notion: developers.notion.com
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Generic webhook (Zapier, Make, n8n, custom)
WEBHOOK_URL=

# ── Storage ───────────────────────────────────────────────────────────────────
# "chroma"   → local ChromaDB files (default, zero setup)
# "supabase" → hosted pgvector (free tier at supabase.com)
VECTOR_STORE=chroma
CHROMA_PATH=./nexus_chroma_db

# Supabase (if VECTOR_STORE=supabase)
SUPABASE_URL=
SUPABASE_KEY=

# Redis (optional, for caching — leave empty to skip)
REDIS_URL=

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── SaaS Auth (optional, for multi-user self-hosted) ─────────────────────────
ENABLE_AUTH=false
JWT_SECRET=change-this-to-a-random-string-in-production
NEXUS_API_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────
ENABLE_PHOENIX=false
PHOENIX_PORT=6006

# ── Deployment ────────────────────────────────────────────────────────────────
# Your public domain or IP (set after deploying)
PUBLIC_URL=http://localhost
